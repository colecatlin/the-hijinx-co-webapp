{
  "name": "HomepageSettings",
  "type": "object",
  "description": "Homepage configuration \u2014 image settings (key/image_url) and editorial override settings (active=true singleton)",
  "properties": {
    "key": {
      "type": "string",
      "description": "Section key for image background records (e.g. apparel_bg)"
    },
    "label": {
      "type": "string",
      "description": "Display label for image background records"
    },
    "image_url": {
      "type": "string",
      "description": "Background image URL for a section"
    },
    "active": {
      "type": "boolean",
      "default": false,
      "description": "If true, this is the active editorial settings singleton record"
    },
    "homepage_mode": {
      "type": "string",
      "enum": [
        "auto",
        "editorial",
        "mixed"
      ],
      "default": "mixed"
    },
    "featured_story_id": {
      "type": "string"
    },
    "featured_driver_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "featured_track_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "featured_series_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "featured_event_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "featured_media_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "featured_product_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "spotlight_driver_id": {
      "type": "string"
    },
    "spotlight_event_id": {
      "type": "string"
    },
    "ticker_override_items": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "hero_ticker_items": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "spotlight_mode": {
      "type": "string",
      "enum": [
        "auto",
        "manual",
        "mixed"
      ],
      "default": "mixed"
    },
    "featured_entities_mode": {
      "type": "string",
      "enum": [
        "auto",
        "manual",
        "mixed"
      ],
      "default": "mixed"
    },
    "activity_feed_mode": {
      "type": "string",
      "enum": [
        "auto",
        "manual",
        "mixed"
      ],
      "default": "auto"
    },
    "updated_by_user_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "social_instagram_url": {
      "type": "string",
      "description": "Instagram profile URL"
    },
    "social_instagram_handle": {
      "type": "string",
      "description": "Instagram handle (e.g. @hijinxco)"
    },
    "social_x_url": {
      "type": "string",
      "description": "X (Twitter) profile URL"
    },
    "social_x_handle": {
      "type": "string",
      "description": "X handle (e.g. @hijinxco)"
    },
    "social_facebook_url": {
      "type": "string",
      "description": "Facebook page URL"
    },
    "social_facebook_handle": {
      "type": "string",
      "description": "Facebook page name or handle"
    },
    "social_youtube_url": {
      "type": "string",
      "description": "YouTube channel URL"
    },
    "social_youtube_handle": {
      "type": "string",
      "description": "YouTube channel name or handle"
    },
    "social_tiktok_url": {
      "type": "string",
      "description": "TikTok profile URL"
    },
    "social_tiktok_handle": {
      "type": "string",
      "description": "TikTok handle (e.g. @hijinxco)"
    },
    "social_linkedin_url": {
      "type": "string",
      "description": "LinkedIn page URL"
    },
    "social_linkedin_handle": {
      "type": "string",
      "description": "LinkedIn company name or page handle"
    },
    "social_threads_url": {
      "type": "string",
      "description": "Threads profile URL"
    },
    "social_threads_handle": {
      "type": "string",
      "description": "Threads handle (e.g. @hijinxco)"
    },
    "social_snapchat_url": {
      "type": "string",
      "description": "Snapchat profile URL"
    },
    "social_snapchat_handle": {
      "type": "string",
      "description": "Snapchat username"
    },
    "social_discord_url": {
      "type": "string",
      "description": "Discord server invite URL"
    },
    "social_discord_handle": {
      "type": "string",
      "description": "Discord server name or community tag"
    },
    "social_hashtags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "List of recommended community hashtags (e.g. #hijinx, #motorsports)"
    }
  },
  "required": []
}